# =============================================================================
# BACKEND SERVER – copy to .env in this folder (server/). Do not commit .env.
# Never put secrets in code. See server/README.md for full setup.
# =============================================================================

# Server port (default 3000). Hosting (e.g. Render, AWS) often sets PORT.
PORT=3000

# -----------------------------------------------------------------------------
# MongoDB (required). Prefer full URI.
# -----------------------------------------------------------------------------
# Option 1: full connection string (recommended)
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/dwellsecure?retryWrites=true&w=majority

# Option 2: separate vars (config.js builds the URI)
# MONGODB_USER=your_db_user
# MONGODB_PASSWORD=your_db_password
# MONGODB_HOST=cluster.mongodb.net
# MONGODB_DB=dwellsecure

# -----------------------------------------------------------------------------
# Auth (required in production)
# -----------------------------------------------------------------------------
# JWT secret for signing tokens. Generate a long random string; do not use the default in production.
JWT_SECRET=your-long-random-secret-change-in-production

# -----------------------------------------------------------------------------
# CORS (optional). Comma-separated allowed origins. Leave unset to allow all.
# -----------------------------------------------------------------------------
# CORS_ORIGIN=https://your-app.web.app,https://your-domain.com

# -----------------------------------------------------------------------------
# Firebase Storage (optional). Needed for POST /api/upload-media (photo uploads).
# -----------------------------------------------------------------------------
# Bucket name, e.g. your-project.firebasestorage.app
# FIREBASE_STORAGE_BUCKET=

# One of: service account JSON string, or path to JSON key file (do not commit the key file).
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# FIREBASE_SERVICE_ACCOUNT_PATH=./path/to/serviceAccountKey.json

# -----------------------------------------------------------------------------
# Address encryption (optional). 32-byte key as 64-char hex.
# When set, address/geo fields are stored encrypted in MongoDB.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# -----------------------------------------------------------------------------
# ADDRESS_ENCRYPTION_KEY=

# -----------------------------------------------------------------------------
# Optional integrations (AI voice-note, geocode, static maps)
# -----------------------------------------------------------------------------
# OPENAI_API_KEY=sk-...
# MAPBOX_ACCESS_TOKEN=pk....
# MAPBOX_TOKEN=   (alternative name; server reads either)
