# Copy to .env and fill in values. Do not commit .env. Never put secrets in code.
PORT=8081
# MongoDB (Option 1: full URI recommended; config also supports MONGO_URI)
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/dwellsecure?retryWrites=true&w=majority
# Option 2: separate user and password (URI built in config.js)
# MONGODB_USER=your_db_user
# MONGODB_PASSWORD=your_db_password
# MONGODB_HOST=cluster.mongodb.net
# MONGODB_DB=dwellsecure
# 32-byte key for encrypting address fields at rest (hex 64 chars or base64). Set in Render env.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADDRESS_ENCRYPTION_KEY=
# Required for AI features (identify shutoff, chat). Set on Render env.
OPENAI_API_KEY=
# Required for geocode, static map images, and MapPicker. Set on Render env.
MAPBOX_ACCESS_TOKEN=
# Optional: restrict CORS to your frontend (comma-separated). Leave empty to allow all.
# CORS_ORIGIN=https://your-app.cloudfront.net,https://your-domain.com
