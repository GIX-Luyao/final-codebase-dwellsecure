# Copy to .env in project root. Do not commit .env.
# Expo only loads .env / .env.local from project root.
# After editing .env, restart: npx expo start

# Backend API (required). Dev: your local server; production: set in EAS/build env.
# EXPO_PUBLIC_API_URL=http://localhost:8081
# EXPO_PUBLIC_API_URL=https://your-backend.onrender.com

# OpenAI and Mapbox are configured on the backend only. Do not set these for app release.
# EXPO_PUBLIC_OPENAI_API_KEY=
# EXPO_PUBLIC_MAPBOX_TOKEN=
