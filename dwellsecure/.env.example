# =============================================================================
# FRONTEND (Expo app) – copy to .env in project root. Do not commit .env.
# Expo loads .env / .env.local from project root. After editing, restart: npx expo start
# =============================================================================

# Backend API base URL (required for login/sync). Point to your backend server.
# Development: use your machine IP when testing on a real device (e.g. http://192.168.1.10:3000)
# Production: set in EAS/build env or your hosting (e.g. https://your-backend.onrender.com)
# EXPO_PUBLIC_API_URL=http://localhost:3000
# EXPO_PUBLIC_API_URL=https://your-backend.onrender.com

# OpenAI and Mapbox are normally configured on the backend only. Do not set these for app release.
# EXPO_PUBLIC_OPENAI_API_KEY=
# EXPO_PUBLIC_MAPBOX_TOKEN=

# =============================================================================
# BACKEND (server) – uses its own .env inside the server folder.
# Copy server/.env.example to server/.env and fill in values. See server/README.md.
# Required: MONGODB_URI, JWT_SECRET (production). Optional: PORT, CORS_ORIGIN,
# FIREBASE_STORAGE_BUCKET, FIREBASE_SERVICE_ACCOUNT_JSON or FIREBASE_SERVICE_ACCOUNT_PATH,
# ADDRESS_ENCRYPTION_KEY, OPENAI_API_KEY, MAPBOX_ACCESS_TOKEN / MAPBOX_TOKEN.
# =============================================================================
